# GNOS3 site — Apache config
# The parent may have WordPress-style rewrite rules from a previous install.
# We disable mod_rewrite in this subtree so our static HTML + contact.php
# are served directly.

<IfModule mod_rewrite.c>
  RewriteEngine Off
</IfModule>

# Prefer the static index over any stray index.php
DirectoryIndex index.html index.php

# No directory listings
Options -Indexes

# Long cache on immutable assets; short on HTML so updates are seen quickly.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 5 minutes"
  ExpiresByType text/css                 "access plus 7 days"
  ExpiresByType application/javascript   "access plus 7 days"
  ExpiresByType image/svg+xml            "access plus 30 days"
  ExpiresByType image/png                "access plus 30 days"
  ExpiresByType image/jpeg               "access plus 30 days"
  ExpiresByType image/x-icon             "access plus 30 days"
  ExpiresByType font/woff2               "access plus 90 days"
</IfModule>

# Explicit charset for HTML
AddDefaultCharset utf-8
